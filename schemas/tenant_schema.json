{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ACI Tenant Data Model",
  "type": "object",
  "required": [
    "apic"
  ],
  "properties": {
    "apic": {
      "type": "object",
      "required": [
        "tenants"
      ],
      "properties": {
        "tenants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_-]{1,64}$"
              },
              "description": {
                "type": "string"
              },
              "vrfs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    }
                  }
                }
              },
              "bridge_domains": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "vrf"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "vrf": {
                      "type": "string"
                    },
                    "subnets": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "ip"
                        ],
                        "properties": {
                          "ip": {
                            "type": "string",
                            "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
                          },
                          "public": {
                            "type": "boolean"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
